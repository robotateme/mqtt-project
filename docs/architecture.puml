@startuml
title MQTT Project - полная архитектура

skinparam shadowing false
skinparam componentStyle rectangle
skinparam defaultFontName DejaVu Sans
skinparam packageStyle rectangle
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #667085
  BackgroundColor #F9FAFB
}
skinparam database {
  BorderColor #475467
  BackgroundColor #EEF4FF
}
skinparam queue {
  BorderColor #475467
  BackgroundColor #ECFDF3
}

actor "Устройства MQTT" as Devices
actor "Пользователь / оператор" as User

component "Browser\nmqtt.local" as Browser
component "nginx / ingress\nHTTP(S)" as Nginx
component "frontend\nVue 3 + Bootstrap 5" as Frontend
component "php-fpm\nAPI runtime" as PhpFpm

package "API core" as CoreBox {
  component "core Laravel API\napi.mqtt.local" as Core
  component "Application code\nstrict_types\nfinal/readonly services" as CoreCode
  component "JWT Auth\nAdmin API" as Auth
  component "Packet interpreter" as Interpreter
  component "Kafka consumer\nphp artisan kafka:consume-packets" as CoreConsumer
  component "Horizon\n/horizon" as Horizon
  component "Telescope\n/telescope" as Telescope
  component "Mercure publisher client" as MercureClient
}

package "Integration buses\nhorizontal scale" as BusBox {
  component "bus A\nMQTT worker\nMQTT_TOPIC=devices/+/telemetry" as BusA
  component "bus B\nMQTT worker\nMQTT_TOPIC=devices/+/state" as BusB
  component "bus N\nMQTT worker\nper topic group or broker cluster" as BusN
  component "Redis outbox publisher\nXREADGROUP -> Kafka -> XACK" as OutboxPublisher
  component "Runtime status HTTP\nper bus instance" as BusHttp
}

package "MQTT ingress" as MqttBox {
  component "Mosquitto cluster A\nMQTT / WebSocket" as MosquittoA
  component "Mosquitto cluster B\noptional isolated broker set" as MosquittoB
  component "Mosquitto cluster N\nper tenant/site/load domain" as MosquittoN
}

queue "Kafka\nmqtt.events" as Kafka
database "PostgreSQL\ncore data" as PostgreSQL
database "ClickHouse\npackets" as ClickHouse
database "Redis\nqueues/cache" as Redis
queue "Redis Streams outbox\nmqtt:outbox\nSET NX dedupe" as RedisOutbox
component "Mercure Hub" as Mercure

User --> Browser : открывает frontend
Browser --> Nginx : http://mqtt.local
Browser --> Nginx : http://api.mqtt.local/api/*
Browser --> Mercure : EventSource subscribe\nMERCURE_PUBLIC_URL

Nginx --> Frontend : static files
Nginx --> PhpFpm : FastCGI
PhpFpm --> Core : Laravel request lifecycle
Core --> CoreCode : typed application layer
Core --> Auth : register/login/refresh/me
Core --> PostgreSQL : users, devices,\nsessions, Telescope
Core --> Redis : cache, queues
Core --> Horizon : queue dashboard
Core --> Telescope : observability
Core --> MercureClient : realtime events
MercureClient --> Mercure : publish\nMERCURE_INTERNAL_URL

Devices --> MosquittoA : MQTT publish
Devices --> MosquittoB : MQTT publish
Devices --> MosquittoN : MQTT publish
MosquittoA --> BusA : topic subscription
MosquittoA --> BusB : topic subscription
MosquittoB --> BusN : dedicated bus
MosquittoN --> BusN : dedicated bus
BusA --> RedisOutbox : XADD packet
BusB --> RedisOutbox : XADD packet
BusN --> RedisOutbox : XADD packet
RedisOutbox --> OutboxPublisher : XREADGROUP
OutboxPublisher --> Kafka : publish events\nkey=mqtt topic\nvalue=payload
OutboxPublisher --> RedisOutbox : XACK after Kafka flush
BusHttp --> Nginx : health/ready
CoreConsumer --> Kafka : consume mqtt.events
CoreConsumer --> Interpreter : parse topic/payload
CoreConsumer --> ClickHouse : JSONEachRow inserts
CoreConsumer --> MercureClient : packet notifications

note right of BusBox
Экземпляров bus может быть несколько.
Их можно разделять по MQTT topic filter,
tenant, site, домену нагрузки или Mosquitto-кластеру.

Все bus сначала пишут в Redis Streams.
Redis SET NX EX используется для краткосрочной дедупликации.

Publisher отправляет единый Kafka-контракт:
key = MQTT topic
value = MQTT payload
end note

note bottom of Mercure
Публичный URL:
MERCURE_PUBLIC_URL

Внутренний URL:
MERCURE_INTERNAL_URL
end note

note right of CoreCode
PHP-файлы проекта используют declare(strict_types=1).
Сервисы приложения, handlers и тесты помечаются final,
если наследование не является частью контракта.
Иммутабельные сервисные объекты используют readonly-конструкторы.
Eloquent-модели остаются не final из-за точек расширения Laravel.
end note

@enduml
