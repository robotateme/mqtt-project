{
    "name": "mqtt-project/bus",
    "description": "Integration bus: MQTT ingress to Kafka.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4 || ^8.5",
        "ext-rdkafka": "*",
        "ext-redis": "*",
        "php-mqtt/client": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Bus\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "mqtt:consume": "php bin/mqtt-consume.php",
        "test": "phpunit --colors=always",
        "phpstan": "phpstan analyse --configuration=phpstan.neon --memory-limit=1G --no-progress",
        "psalm": "psalm --config=psalm.xml --no-cache --no-progress",
        "analyse": [
            "@phpstan",
            "@psalm"
        ]
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.5",
        "vimeo/psalm": "^6.16"
    }
}
