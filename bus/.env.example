APP_ENV=local
APP_DEBUG=true
BUS_ID=bus-mqtt-kafka-1

MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_CLIENT_ID=bus-mqtt-kafka
MQTT_TOPIC=#
MQTT_QOS=1
MQTT_CLEAN_SESSION=false
MQTT_USERNAME=
MQTT_PASSWORD=

KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=mqtt.events
KAFKA_BATCH_SIZE=100
KAFKA_LINGER_MS=100
KAFKA_MAX_OUTSTANDING=10000
KAFKA_BACKPRESSURE_TIMEOUT_MS=5000
KAFKA_MESSAGE_TIMEOUT_MS=30000

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=2.5

OUTBOX_STREAM=mqtt:outbox
OUTBOX_GROUP=bus-publishers
OUTBOX_CONSUMER=
OUTBOX_BUS_ID=
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_LENGTH=100000
OUTBOX_DEDUPE_TTL_SECONDS=86400
OUTBOX_BLOCK_MS=1

BUS_STATUS_FILE=/var/www/bus/storage/runtime/status.json
BUS_STATUS_INTERVAL_MS=1000
