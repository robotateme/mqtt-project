pipeline {
    agent any

    environment {
        DEPLOY_IMAGE_TAG = "${env.GIT_COMMIT}"
        COMPOSE_FILE = "deploy/docker-compose.yml"
        COMPOSE_ENV_FILE = "deploy/.env"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Validate') {
            steps {
                sh 'docker compose -f "$COMPOSE_FILE" --env-file "$COMPOSE_ENV_FILE" config >/dev/null'
            }
        }

        stage('Build') {
            steps {
                sh 'docker compose -f "$COMPOSE_FILE" --env-file "$COMPOSE_ENV_FILE" build --pull'
            }
        }

        stage('Deploy') {
            steps {
                sh 'docker compose -f "$COMPOSE_FILE" --env-file "$COMPOSE_ENV_FILE" up -d --remove-orphans'
                sh 'docker compose -f "$COMPOSE_FILE" --env-file "$COMPOSE_ENV_FILE" exec -T core-php php artisan migrate --force'
                sh 'docker compose -f "$COMPOSE_FILE" --env-file "$COMPOSE_ENV_FILE" exec -T core-php php artisan clickhouse:migrate'
            }
        }

        stage('Healthcheck') {
            steps {
                sh 'docker compose -f "$COMPOSE_FILE" --env-file "$COMPOSE_ENV_FILE" exec -T core-php php artisan route:list >/dev/null'
                sh 'curl -fsS "http://127.0.0.1:${CORE_HTTP_PORT:-8080}/health"'
                sh 'curl -fsS "http://127.0.0.1:${FRONTEND_HTTP_PORT:-8081}/" >/dev/null'
                sh 'curl -fsS "http://127.0.0.1:${BUS_HTTP_PORT:-8082}/health"'
            }
        }
    }
}
