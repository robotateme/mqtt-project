PROJECT_NAME=mqtt-project
DEPLOY_IMAGE_TAG=local

APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:change_me
APP_URL=https://api.example.com
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
LOG_CHANNEL=stderr
LOG_LEVEL=info
BCRYPT_ROUNDS=12

CORE_HTTP_PORT=8080
FRONTEND_HTTP_PORT=8081
BUS_HTTP_PORT=8082
MERCURE_HTTP_PORT=1337

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=core
DB_USERNAME=core
DB_PASSWORD=change_me
POSTGRES_DB=core
POSTGRES_USER=core
POSTGRES_PASSWORD=change_me

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_DB=0
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

KAFKA_BROKERS=kafka:9092
KAFKA_CONSUMER_GROUP=core-packet-storage
KAFKA_PACKET_TOPIC=mqtt.events
KAFKA_OFFSET_RESET=earliest
KAFKA_CONSUME_TIMEOUT_MS=1000
KAFKA_BATCH_SIZE=500

CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DATABASE=core
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=change_me
CLICKHOUSE_PACKETS_TABLE=mqtt_packets

PACKET_DEVICE_TOPIC_REGEX=~(?:^|/)devices?/([^/]+)~

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
HORIZON_PATH=horizon
TELESCOPE_ENABLED=false
TELESCOPE_PATH=telescope
TELESCOPE_DRIVER=database
TELESCOPE_QUEUE_CONNECTION=redis
TELESCOPE_QUEUE=telescope

MERCURE_PUBLIC_URL=https://mercure.example.com/.well-known/mercure
MERCURE_INTERNAL_URL=http://mercure/.well-known/mercure
MERCURE_PUBLISHER_JWT_KEY=change_me
MERCURE_SUBSCRIBER_JWT_KEY=change_me
MERCURE_JWT_ALGORITHM=HS256

JWT_SECRET=change_me
JWT_ISSUER=https://api.example.com
JWT_AUDIENCE=https://api.example.com
JWT_TTL_MINUTES=60
JWT_REFRESH_TTL_MINUTES=10080
JWT_LEEWAY_SECONDS=30

MAIL_MAILER=log
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=MQTT

BUS_ID=bus-prod-1
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_CLIENT_ID=bus-prod
MQTT_TOPIC=#
MQTT_QOS=1
MQTT_CLEAN_SESSION=false
MQTT_USERNAME=
MQTT_PASSWORD=

KAFKA_TOPIC=mqtt.events
KAFKA_BATCH_SIZE=100
KAFKA_LINGER_MS=100
KAFKA_MAX_OUTSTANDING=10000
KAFKA_BACKPRESSURE_TIMEOUT_MS=5000
KAFKA_MESSAGE_TIMEOUT_MS=30000

OUTBOX_STREAM=mqtt:outbox
OUTBOX_GROUP=bus-publishers
OUTBOX_CONSUMER=
OUTBOX_BUS_ID=
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_LENGTH=100000
OUTBOX_DEDUPE_TTL_SECONDS=86400
OUTBOX_BLOCK_MS=1

BUS_STATUS_FILE=/var/www/bus/storage/runtime/status.json
BUS_STATUS_INTERVAL_MS=1000
METRICS_ENABLED=true
METRICS_STORAGE=redis
METRICS_NAMESPACE=bus
METRICS_REDIS_PREFIX=bus:prometheus:

VITE_API_BASE_URL=https://api.example.com
